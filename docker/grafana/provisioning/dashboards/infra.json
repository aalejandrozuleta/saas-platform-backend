{
  "title": "SaaS Platform – Infra",
  "uid": "saas-infra",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Container CPU (cores)",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (rate(container_cpu_usage_seconds_total{container_label_com_docker_compose_service!=\"\"}[2m]))",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Container Memory (MB)",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 7 },
      "targets": [
        {
          "expr": "sum by (container_label_com_docker_compose_service) (container_memory_working_set_bytes{container_label_com_docker_compose_service!=\"\"}) / 1024 / 1024",
          "legendFormat": "{{container_label_com_docker_compose_service}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Postgres Connections",
      "gridPos": { "x": 0, "y": 7, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(pg_stat_activity_count{datname=\"auth_db\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Postgres Tx/s",
      "gridPos": { "x": 6, "y": 7, "w": 12, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(pg_stat_database_xact_commit{datname=\"auth_db\"}[2m]) + rate(pg_stat_database_xact_rollback{datname=\"auth_db\"}[2m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Redis Connected Clients",
      "gridPos": { "x": 18, "y": 7, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Ops/s",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[2m])",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Memory (MB)",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 6 },
      "targets": [
        {
          "expr": "redis_memory_used_bytes / 1024 / 1024",
          "refId": "A"
        }
      ]
    }
  ]
}
