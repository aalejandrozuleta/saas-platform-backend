###############################################
# Dependencies — installed inside the container
###############################################
**/node_modules

###############################################
# Build artifacts — regenerated inside container
###############################################
**/dist
**/build
**/coverage

# Prisma generated clients — recreated via `prisma generate` during image build
**/generated

###############################################
# Test files — not needed for compilation
###############################################
**/*.spec.ts
**/*.test.ts
**/__tests__/
**/test-results/
**/playwright-report/
**/.jest-cache

###############################################
# Environment / Secrets
# (injected via env_file or --env in Compose)
###############################################
**/.env
**/.env.*
!**/.env.example

###############################################
# Version control
###############################################
.git
.gitignore
.gitattributes
.github/

###############################################
# CI / QA tooling
###############################################
sonar-project.properties
.sonar/
.scannerwork/
.sonarlint
.codex

###############################################
# Documentation
###############################################
docs/
README*
CHANGELOG*
**/*.md

###############################################
# Docker (avoid self-inclusion)
###############################################
docker/

###############################################
# Editor / OS
###############################################
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*.swo
*.log
**/logs/

###############################################
# Git hooks
###############################################
.husky/

###############################################
# TypeScript cache
###############################################
*.tsbuildinfo
**/*.tsbuildinfo

###############################################
# Temporary files
###############################################
*.tmp
*.temp
