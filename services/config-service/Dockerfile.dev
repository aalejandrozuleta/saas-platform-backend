FROM node:24-alpine

WORKDIR /app

ENV PNPM_STORE_PATH=/pnpm-store

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

RUN corepack enable && corepack prepare --activate

COPY .npmrc ./
COPY tsconfig.base.json ./

COPY services ./services
COPY shared ./shared

# Instalar dependencias y generar cliente Prisma en una sola capa
RUN pnpm install --frozen-lockfile # NOSONAR: scripts required for prisma binary generation
RUN pnpm --filter config-service exec prisma generate

WORKDIR /app/services/config-service

EXPOSE 3002

ENTRYPOINT ["/bin/sh", "/app/services/config-service/docker-entrypoint.sh"]
