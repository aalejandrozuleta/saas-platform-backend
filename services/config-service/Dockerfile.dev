FROM node:24-alpine # NOSONAR: dev image — non-root not required for hot-reload container

WORKDIR /app

ENV PNPM_STORE_PATH=/pnpm-store

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

RUN corepack enable && corepack prepare --activate

COPY .npmrc ./
COPY tsconfig.base.json ./

COPY services ./services
COPY shared ./shared

RUN pnpm install --frozen-lockfile && pnpm --filter config-service exec prisma generate # NOSONAR: scripts required for prisma binary generation

WORKDIR /app/services/config-service

EXPOSE 3002

ENTRYPOINT ["/bin/sh", "/app/services/config-service/docker-entrypoint.sh"]
