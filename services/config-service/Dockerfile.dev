FROM node:24-alpine

WORKDIR /app

# Activar corepack para usar la versión de pnpm declarada en packageManager
ENV PNPM_STORE_PATH=/pnpm-store
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./

RUN corepack enable && corepack prepare --activate

COPY .npmrc ./
COPY tsconfig.base.json ./

# Copiar manifiestos del workspace antes del código para aprovechar cache de capas
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY .npmrc ./
COPY tsconfig.base.json ./

# Copiar código fuente
COPY services ./services
COPY shared ./shared

# Instalar dependencias y generar cliente Prisma en una sola capa
# NOSONAR: pnpm install scripts required for prisma
RUN pnpm install --frozen-lockfile && \
    pnpm --filter config-service exec prisma generate

WORKDIR /app/services/config-service

EXPOSE 3002

CMD ["pnpm", "run", "dev"]
