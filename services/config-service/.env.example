NODE_ENV=development
PORT=3002

# PostgreSQL — config-service tiene su propia base de datos
DATABASE_URL=postgresql://config_user:config_pass@config-postgres:5433/config_db

# MongoDB — audit logs de cambios de configuración
MONGO_URL=mongodb://mongo:27017/config_audit

# OpenTelemetry
OTEL_SERVICE_NAME=config-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces

# Redis — caché de configuraciones
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# TTL en segundos para cachear valores de configuración en Redis
CONFIG_CACHE_TTL=300
