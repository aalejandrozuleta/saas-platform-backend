generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Estado de mantenimiento ────────────────────────────────────────────────
// Fila única. Se upserta por id fijo ("singleton").
model MaintenanceConfig {
  id        String   @id @default(uuid())
  enabled   Boolean  @default(false)
  readOnly  Boolean  @default(false)
  message   String?
  updatedBy String?
  updatedAt DateTime @updatedAt
}

// ─── Ventanas de mantenimiento programadas ──────────────────────────────────
model MaintenanceWindow {
  id          String    @id @default(uuid())
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  isActive    Boolean   @default(true)
  notifiedAt  DateTime?
  createdBy   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([startAt])
  @@index([endAt])
  @@index([isActive])
}

// ─── Feature flags de plataforma ─────────────────────────────────────────────
// key = nombre del servicio / módulo (ej: "auth-service", "billing", "dashboard")
// environment = null → aplica a todos los entornos
model FeatureFlag {
  id          String   @id @default(uuid())
  key         String
  enabled     Boolean  @default(true)
  environment String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([key, environment])
  @@index([key])
  @@index([enabled])
}
