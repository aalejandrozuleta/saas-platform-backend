{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@saas/shared": ["../../shared/index.ts"],
      "@saas/shared/*": ["../../shared/*"],

      "@domain/*": ["./src/domain/*"],
      "@application/*": ["./src/application/*"],
      "@infrastructure/*": ["./src/infrastructure/*"],
      "@modules/*": ["./src/modules/*"],
      "@config/*": ["./src/config/*"],
      "@auth-prisma/client": ["./node_modules/.prisma/auth-client"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}