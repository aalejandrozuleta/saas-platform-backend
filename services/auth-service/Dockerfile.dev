FROM node:24-alpine

WORKDIR /app

ENV PNPM_STORE_PATH=/pnpm-store

# Instalar pnpm
RUN npm install -g pnpm

# Copiar archivos del workspace
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY tsconfig.base.json ./

# Copiar código
COPY services ./services
COPY shared ./shared

# Instalar dependencias y generar Prisma en una sola capa
# NOSONAR: pnpm install scripts required for prisma
RUN pnpm install && \
    pnpm --filter auth-service exec prisma generate

WORKDIR /app/services/auth-service

EXPOSE 3001

CMD ["pnpm", "run", "dev"]