FROM node:24-alpine

WORKDIR /app

# Activar corepack para usar la versión de pnpm declarada en packageManager
ENV PNPM_STORE_PATH=/pnpm-store
RUN corepack enable && corepack prepare --activate

# Copiar manifiestos del workspace antes del código para aprovechar cache de capas
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY .npmrc ./
COPY tsconfig.base.json ./

# Copiar código fuente
COPY services ./services
COPY shared ./shared

# NOSONAR: pnpm install scripts required for prisma
RUN pnpm install --frozen-lockfile

WORKDIR /app/services/api-gateway

EXPOSE 3000

CMD ["pnpm", "run", "dev"]
