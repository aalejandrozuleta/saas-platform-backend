{
  "name": "api-gateway",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "predev": "pnpm --filter @saas/shared build",
    "dev": "nest start --watch",
    "devs": "node --watch --require ts-node/register --require tsconfig-paths/register src/main.ts",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test:cov": "jest --config jest.config.cjs --coverage",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --watch --config jest.config.cjs",
    "test:watch:cov": "jest --watch --coverage --config jest.config.cjs",
    "docs": "typedoc --options typedoc.json"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "11.1.17",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.17",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "11.1.17",
    "@nestjs/swagger": "^11.2.6",
    "@saas/shared": "workspace:*",
    "@types/jest": "^30.0.0",
    "axios": "^1.13.4",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jest": "^30.2.0",
    "jsonwebtoken": "^9.0.3",
    "opossum": "^9.0.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/testing": "11.1.17",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/opossum": "^8.1.9",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist",
    "prisma",
    "package.json",
    "pnpm-lock.yaml"
  ]
}
