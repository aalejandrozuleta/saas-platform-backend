{
  "name": "saas-platform",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "eslint . --ignore-pattern '**/coverage/**' --ignore-pattern '**/dist/**' --ignore-pattern '**/*.d.ts'",
    "lint:fix": "eslint . --fix --ignore-pattern '**/coverage/**' --ignore-pattern '**/dist/**' --ignore-pattern '**/*.d.ts'",
    "format": "prettier . --write",
    "lint-staged": "lint-staged",
    "dev": "docker compose -f docker/docker-compose.dev.yml up --build --watch",
    "dev:down": "docker compose -f docker/docker-compose.dev.yml down",
    "dev:reset": "docker compose -f docker/docker-compose.dev.yml down -v",
    "dev:auth": "nest start auth-service --watch",
    "prod:up": "docker compose -f docker/docker-compose.prod.yml up --build -d",
    "prod:down": "docker compose -f docker/docker-compose.prod.yml down",
    "sonar:local": "dotenv -e .env.sonar -- sonar-scanner",
    "test": "pnpm -r --parallel test",
    "test:watch": "pnpm -r --parallel test:watch",
    "test:cov": "pnpm -r test:cov",
    "test:auth": "pnpm --filter auth-service test",
    "test:gateway": "pnpm --filter api-gateway test",
    "build": "pnpm -r --parallel --workspace-concurrency=4 build",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "docs:code": "pnpm -r run docs"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@swc/core": "^1.15.18",
    "@swc/jest": "^0.2.39",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.7",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^5.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unused-imports": "^4.3.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prisma": "^7.3.0",
    "supertest": "^7.2.2",
    "typedoc": "^0.28.17"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nestjs/common": "11.1.13",
    "@nestjs/config": "3.2.3",
    "@nestjs/core": "11.1.13",
    "@nestjs/mongoose": "11.0.4",
    "@nestjs/platform-express": "11.1.13",
    "@prisma/client": "^7.3.0",
    "ioredis": "^5.10.0",
    "mongoose": "^9.1.5"
  },
  "pnpm": {
    "overrides": {
      "@nestjs/common": "11.1.13",
      "@nestjs/core": "11.1.13",
      "@nestjs/platform-express": "11.1.13",
      "@nestjs/config": "3.2.3",
      "@nestjs/mongoose": "11.0.4"
    },
    "ignoredBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "argon2",
      "prisma",
      "unrs-resolver"
    ]
  },
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70"
}
